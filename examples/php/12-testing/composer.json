{
    "name": "swp/12-testing",
    "description": "Тема 12 – Тестване с PHPUnit (пример за курса по Сървърно уеб програмиране)",
    "type": "project",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "tests/CalculatorTest.php"
        ]
    },
    "scripts": {
        "test": "phpunit --colors=always tests/"
    },
    "config": {
        "optimize-autoloader": true
    }
}
